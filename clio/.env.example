# Root compose env — used by docker compose for variable substitution only.
# Copy to .env and fill in values, or run: python -m generate_env
#
# NOTE (PoC): SSL/TLS vars removed. Plain connections used for convenience.
# In production add POSTGRES_SSL, REDIS_SSL, REDIS_ENCRYPTION_KEY and TLS certs.

POSTGRES_USER=clio
POSTGRES_PASSWORD=changeme
POSTGRES_DB=redteamlogger
REDIS_PASSWORD=changeme
