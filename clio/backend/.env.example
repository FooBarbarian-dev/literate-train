# Backend Django environment — copy to .env and fill in real values.
# Run `clio-env` to generate a complete .env with random secrets automatically.
#
# Variables consumed by Django settings (backend/backend/settings/base.py)
# unless noted otherwise.

# ---------------------------------------------------------------------------
# Django core
# ---------------------------------------------------------------------------
DJANGO_SETTINGS_MODULE=backend.settings.development
DJANGO_SECRET_KEY=django-insecure-change-me-in-production
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# ---------------------------------------------------------------------------
# Database (PostgreSQL)
# ---------------------------------------------------------------------------
POSTGRES_DB=redteamlogger
POSTGRES_USER=clio
POSTGRES_PASSWORD=changeme
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ---------------------------------------------------------------------------
# Cache / Celery broker (Redis)
# ---------------------------------------------------------------------------
# Full connection URL including password if set:
#   redis://:PASSWORD@HOST:PORT/DB
REDIS_URL=redis://localhost:6379/0

# ---------------------------------------------------------------------------
# CORS
# ---------------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ---------------------------------------------------------------------------
# JWT authentication
# ---------------------------------------------------------------------------
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=30
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# ---------------------------------------------------------------------------
# File storage paths (defaults to subdirs of the Django BASE_DIR)
# ---------------------------------------------------------------------------
# EVIDENCE_ROOT=/path/to/evidence
# DATA_ROOT=/path/to/data
# EXPORT_ROOT=/path/to/exports

# ---------------------------------------------------------------------------
# Application credentials (used by entrypoint.sh seed logic, not settings.py)
# ---------------------------------------------------------------------------
ADMIN_PASSWORD=changeme
USER_PASSWORD=changeme

# ---------------------------------------------------------------------------
# Threat Intel / RAG / vLLM  (optional — only needed for the chat feature)
# ---------------------------------------------------------------------------
VLLM_BASE_URL=http://localhost:8000/v1
VLLM_API_KEY=not-needed
VLLM_MODEL_NAME=
NVD_API_KEY=
# One of: auto | vllm | sentence-transformers
THREAT_RAG_EMBEDDING_BACKEND=auto
